theorem lintegral_max {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) (hg : Measurable g) :
    ‚ąę‚ĀĽ x, max (f x) (g x) ‚ąāőľ =

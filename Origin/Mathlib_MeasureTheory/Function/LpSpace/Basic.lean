    (g : Lp E p őľc) {f : ő≤ ‚Üí ő≥} (hf : MeasurePreserving f őľb őľc) {f' : őĪ ‚Üí ő≤}
    (hf' : MeasurePreserving f' őľ őľb) :
    (compMeasurePreserving (f ‚ąė f') (hf.comp hf')) g =
    (compMeasurePreserving f' hf') ((compMeasurePreserving f hf) g) := by
  simp [compMeasurePreserving_comp hf hf']

theorem compMeasurePreserving_iterate {f : őĪ ‚Üí őĪ} (hf : MeasurePreserving f őľ őľ) (n : ‚Ąē) :
    (compMeasurePreserving (E := E) (p := p) f hf)^[n] =
    compMeasurePreserving f^[n] (MeasurePreserving.iterate hf n) := by
  funext
  induction n with
  | zero => simp
  | succ n h =>
    nth_rewrite 1 [add_comm n 1]
    simp [Function.iterate_add, h, compMeasurePreserving_comp (hf.iterate n) hf]

def compMeasurePreserving‚āó (f : őĪ ‚Üí ő≤) (hf : MeasurePreserving f őľ őľb) :
    Lp E p őľb ‚Üí‚āó[ūĚēú] Lp E p őľ where
  __ := compMeasurePreserving f hf
  map_smul' c g := by rcases g with ‚ü®‚ü®_‚ü©, _‚ü©; rfl

def compMeasurePreserving‚āóŠĶĘ [Fact (1 ‚Č§ p)] (f : őĪ ‚Üí ő≤) (hf : MeasurePreserving f őľ őľb) :
    Lp E p őľb ‚Üí‚āóŠĶĘ[ūĚēú] Lp E p őľ where
  toLinearMap := compMeasurePreserving‚āó ūĚēú f hf
  norm_map' := (norm_compMeasurePreserving ¬∑ hf)

theorem LipschitzWith.comp_memLp {őĪ E F} {K} [MeasurableSpace őĪ] {őľ : Measure őĪ}
    [NormedAddCommGroup E] [NormedAddCommGroup F] {f : őĪ ‚Üí E} {g : E ‚Üí F} (hg : LipschitzWith K g)
    (g0 : g 0 = 0) (hL : MemLp f p őľ) : MemLp (g ‚ąė f) p őľ :=
  have : ‚ąÄ x, ‚ÄĖg (f x)‚ÄĖ ‚Č§ K * ‚ÄĖf x‚ÄĖ := fun x ‚Ü¶ by
    -- TODO: add `LipschitzWith.nnnorm_sub_le` and `LipschitzWith.nnnorm_le`
    simpa [g0] using hg.norm_sub_le (f x) 0
  hL.of_le_mul (hg.continuous.comp_aestronglyMeasurable hL.1) (Eventually.of_forall this)

theorem MeasureTheory.MemLp.of_comp_antilipschitzWith {őĪ E F} {K'} [MeasurableSpace őĪ]
    {őľ : Measure őĪ} [NormedAddCommGroup E] [NormedAddCommGroup F] {f : őĪ ‚Üí E} {g : E ‚Üí F}
    (hL : MemLp (g ‚ąė f) p őľ) (hg : UniformContinuous g) (hg' : AntilipschitzWith K' g)
    (g0 : g 0 = 0) : MemLp f p őľ := by
  have A : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ K' * ‚ÄĖg (f x)‚ÄĖ := by
    intro x
    -- TODO: add `AntilipschitzWith.le_mul_nnnorm_sub` and `AntilipschitzWith.le_mul_norm`
    rw [‚Üź dist_zero_right, ‚Üź dist_zero_right, ‚Üź g0]
    apply hg'.le_mul_dist
  have B : AEStronglyMeasurable f őľ :=
    (hg'.isUniformEmbedding hg).isEmbedding.aestronglyMeasurable_comp_iff.1 hL.1
  exact hL.of_le_mul B (Filter.Eventually.of_forall A)

lemma MeasureTheory.MemLp.continuousLinearMap_comp [NontriviallyNormedField ūĚēú]
    [NormedSpace ūĚēú E] [NormedSpace ūĚēú F] {f : őĪ ‚Üí E}
    (h_Lp : MemLp f p őľ) (L : E ‚ÜíL[ūĚēú] F) :
    MemLp (fun x ‚Ü¶ L (f x)) p őľ :=
  LipschitzWith.comp_memLp L.lipschitz (by simp) h_Lp

theorem memLp_comp_iff_of_antilipschitz {őĪ E F} {K K'} [MeasurableSpace őĪ] {őľ : Measure őĪ}
    [NormedAddCommGroup E] [NormedAddCommGroup F] {f : őĪ ‚Üí E} {g : E ‚Üí F} (hg : LipschitzWith K g)
    (hg' : AntilipschitzWith K' g) (g0 : g 0 = 0) : MemLp (g ‚ąė f) p őľ ‚ÜĒ MemLp f p őľ :=
  ‚ü®fun h => h.of_comp_antilipschitzWith hg.uniformContinuous hg' g0, fun h => hg.comp_memLp g0 h‚ü©

def compLp (hg : LipschitzWith c g) (g0 : g 0 = 0) (f : Lp E p őľ) : Lp F p őľ :=
  ‚ü®AEEqFun.comp g hg.continuous (f : őĪ ‚Üí‚āė[őľ] E), by
    suffices ‚ąÄŠĶź x ‚ąāőľ, ‚ÄĖAEEqFun.comp g hg.continuous (f : őĪ ‚Üí‚āė[őľ] E) x‚ÄĖ ‚Č§ c * ‚ÄĖf x‚ÄĖ from
      Lp.mem_Lp_of_ae_le_mul this
    filter_upwards [AEEqFun.coeFn_comp g hg.continuous (f : őĪ ‚Üí‚āė[őľ] E)] with a ha
    simp only [ha]
    rw [‚Üź dist_zero_right, ‚Üź dist_zero_right, ‚Üź g0]
    exact hg.dist_le_mul (f a) 0‚ü©

theorem coeFn_compLp (hg : LipschitzWith c g) (g0 : g 0 = 0) (f : Lp E p őľ) :
    hg.compLp g0 f =ŠĶź[őľ] g ‚ąė f :=
  AEEqFun.coeFn_comp _ hg.continuous _

theorem compLp_zero (hg : LipschitzWith c g) (g0 : g 0 = 0) : hg.compLp g0 (0 : Lp E p őľ) = 0 := by
  rw [Lp.eq_zero_iff_ae_eq_zero]
  apply (coeFn_compLp _ _ _).trans
  filter_upwards [Lp.coeFn_zero E p őľ] with _ ha
  simp only [ha, g0, Function.comp_apply, Pi.zero_apply]

theorem norm_compLp_sub_le (hg : LipschitzWith c g) (g0 : g 0 = 0) (f f' : Lp E p őľ) :
    ‚ÄĖhg.compLp g0 f - hg.compLp g0 f'‚ÄĖ ‚Č§ c * ‚ÄĖf - f'‚ÄĖ := by
  apply Lp.norm_le_mul_norm_of_ae_le_mul
  filter_upwards [hg.coeFn_compLp g0 f, hg.coeFn_compLp g0 f',
    Lp.coeFn_sub (hg.compLp g0 f) (hg.compLp g0 f'), Lp.coeFn_sub f f'] with a ha1 ha2 ha3 ha4
  simp only [ha1, ha2, ha3, ha4, ‚Üź dist_eq_norm, Pi.sub_apply, Function.comp_apply]
  exact hg.dist_le_mul (f a) (f' a)

theorem norm_compLp_le (hg : LipschitzWith c g) (g0 : g 0 = 0) (f : Lp E p őľ) :
    ‚ÄĖhg.compLp g0 f‚ÄĖ ‚Č§ c * ‚ÄĖf‚ÄĖ := by
  -- squeezed for performance reasons
  simpa only [compLp_zero, sub_zero] using hg.norm_compLp_sub_le g0 f 0

theorem lipschitzWith_compLp [Fact (1 ‚Č§ p)] (hg : LipschitzWith c g) (g0 : g 0 = 0) :
    LipschitzWith c (hg.compLp g0 : Lp E p őľ ‚Üí Lp F p őľ) :=
  -- squeezed for performance reasons
  LipschitzWith.of_dist_le_mul fun f g => by simp only [dist_eq_norm, norm_compLp_sub_le]

theorem continuous_compLp [Fact (1 ‚Č§ p)] (hg : LipschitzWith c g) (g0 : g 0 = 0) :
    Continuous (hg.compLp g0 : Lp E p őľ ‚Üí Lp F p őľ) :=
  (lipschitzWith_compLp hg g0).continuous

def compLp (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) : Lp F p őľ :=
  L.lipschitz.compLp (map_zero L) f

theorem coeFn_compLp (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) : ‚ąÄŠĶź a ‚ąāőľ, (L.compLp f) a = L (f a) :=
  LipschitzWith.coeFn_compLp _ _ _

theorem coeFn_compLp' (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) : L.compLp f =ŠĶź[őľ] fun a => L (f a) :=
  L.coeFn_compLp f

theorem comp_memLp (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) : MemLp (L ‚ąė f) p őľ :=
  (Lp.memLp (L.compLp f)).ae_eq (L.coeFn_compLp' f)

theorem comp_memLp' (L : E ‚ÜíSL[ŌÉ] F) {f : őĪ ‚Üí E} (hf : MemLp f p őľ) : MemLp (L ‚ąė f) p őľ :=
  (L.comp_memLp (hf.toLp f)).ae_eq (EventuallyEq.fun_comp hf.coeFn_toLp _)

theorem _root_.MeasureTheory.MemLp.ofReal {f : őĪ ‚Üí ‚ĄĚ} (hf : MemLp f p őľ) :
    MemLp (fun x => (f x : K)) p őľ :=
  (@RCLike.ofRealCLM K _).comp_memLp' hf

theorem _root_.MeasureTheory.memLp_re_im_iff {f : őĪ ‚Üí K} :
    MemLp (fun x ‚Ü¶ RCLike.re (f x)) p őľ ‚ąß MemLp (fun x ‚Ü¶ RCLike.im (f x)) p őľ ‚ÜĒ
      MemLp f p őľ := by
  refine ‚ü®?_, fun hf => ‚ü®hf.re, hf.im‚ü©‚ü©
  rintro ‚ü®hre, him‚ü©
  convert MeasureTheory.MemLp.add (őĶ := K) hre.ofReal (him.ofReal.const_mul RCLike.I)
  ext1 x
  rw [Pi.add_apply, mul_comm, RCLike.re_add_im]

theorem add_compLp (L L' : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) :
    (L + L').compLp f = L.compLp f + L'.compLp f := by
  ext1
  grw [Lp.coeFn_add, coeFn_compLp']
  refine
    EventuallyEq.trans ?_ (EventuallyEq.fun_add (L.coeFn_compLp' f).symm (L'.coeFn_compLp' f).symm)
  filter_upwards with x
  rw [coe_add', Pi.add_def]

theorem smul_compLp {ūĚēú''} [NormedRing ūĚēú''] [Module ūĚēú'' F] [IsBoundedSMul ūĚēú'' F]
    [SMulCommClass ūĚēú' ūĚēú'' F] (c : ūĚēú'') (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) :
    (c ‚ÄĘ L).compLp f = c ‚ÄĘ L.compLp f := by
  ext1
  grw [Lp.coeFn_smul, coeFn_compLp']
  refine (L.coeFn_compLp' f).mono fun x hx => ?_
  rw [Pi.smul_apply, hx, coe_smul', Pi.smul_def]

theorem norm_compLp_le (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) : ‚ÄĖL.compLp f‚ÄĖ ‚Č§ ‚ÄĖL‚ÄĖ * ‚ÄĖf‚ÄĖ :=
  LipschitzWith.norm_compLp_le _ _ _

def compLp‚āó (L : E ‚ÜíSL[ŌÉ] F) : Lp E p őľ ‚Üí‚āõ‚āó[ŌÉ] Lp F p őľ where
  toFun f := L.compLp f
  map_add' f g := by
    ext1
    filter_upwards [Lp.coeFn_add f g, coeFn_compLp L (f + g), coeFn_compLp L f,
      coeFn_compLp L g, Lp.coeFn_add (L.compLp f) (L.compLp g)]
    intro a ha1 ha2 ha3 ha4 ha5
    simp only [ha1, ha2, ha3, ha4, ha5, map_add, Pi.add_apply]
  map_smul' c f := by
    ext1
    filter_upwards [Lp.coeFn_smul c f, coeFn_compLp L (c ‚ÄĘ f), Lp.coeFn_smul (ŌÉ c) (L.compLp f),
      coeFn_compLp L f] with _ ha1 ha2 ha3 ha4
    simp only [ha1, ha2, ha3, ha4, Pi.smul_apply, map_smul‚āõ‚āó]

def compLpL [Fact (1 ‚Č§ p)] (L : E ‚ÜíSL[ŌÉ] F) : Lp E p őľ ‚ÜíSL[ŌÉ] Lp F p őľ :=
  LinearMap.mkContinuous (L.compLp‚āó p őľ) ‚ÄĖL‚ÄĖ L.norm_compLp_le

theorem coeFn_compLpL [Fact (1 ‚Č§ p)] (L : E ‚ÜíSL[ŌÉ] F) (f : Lp E p őľ) :
    L.compLpL p őľ f =ŠĶź[őľ] fun a => L (f a) :=

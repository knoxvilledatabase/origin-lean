import Origin.Core

/-! # Nonnegative contractions in a C‚čÜ-algebra form an approximate unit

This file shows that the collection of positive contractions (of norm strictly less than one)
in a possibly non-unital C‚čÜ-algebra form a directed set. The key step uses the continuous functional
calculus applied with the functions `fun x : ‚ĄĚ‚Č•0, 1 - (1 + x)‚ĀĽ¬Ļ` and `fun x : ‚ĄĚ‚Č•0, x * (1 - x)‚ĀĽ¬Ļ`,
which are inverses on the interval `{x : ‚ĄĚ‚Č•0 | x < 1}`.

In addition, this file defines `IsIncreasingApproximateUnit` to be a filter `l` that is an
approximate unit contained in the closed unit ball of nonnegative elements. Every C‚čÜ-algebra has
a filter generated by the sections `{x | a ‚Č§ x} ‚ą© closedBall 0 1` for `0 ‚Č§ a` and `‚ÄĖa‚ÄĖ < 1`, and
moreover, this filter is an increasing approximate unit.

## Main declarations

+ `CFC.monotoneOn_one_sub_one_add_inv`: the function `f := fun x : ‚ĄĚ‚Č•0, 1 - (1 + x)‚ĀĽ¬Ļ` is
  *operator monotone* on `Set.Ici (0 : A)` (i.e., `cfc‚āô f` is monotone on `{x : A | 0 ‚Č§ x}`).
+ `Set.InvOn.one_sub_one_add_inv`: the functions `f := fun x : ‚ĄĚ‚Č•0, 1 - (1 + x)‚ĀĽ¬Ļ` and
  `g := fun x : ‚ĄĚ‚Č•0, x * (1 - x)‚ĀĽ¬Ļ` are inverses on `{x : ‚ĄĚ‚Č•0 | x < 1}`.
+ `CStarAlgebra.directedOn_nonneg_ball`: the set `{x : A | 0 ‚Č§ x} ‚ą© Metric.ball 0 1` is directed.
+ `Filter.IsIncreasingApproximateUnit`: a filter `l` is an *increasing approximate unit* if it is an
  approximate unit contained in the closed unit ball of nonnegative elements.
+ `CStarAlgebra.approximateUnit`: the filter generated by the sections
  `{x | a ‚Č§ x} ‚ą© closedBall 0 1` for `0 ‚Č§ a` with `‚ÄĖa‚ÄĖ < 1`.
+ `CStarAlgebra.increasingApproximateUnit`: the filter `CStarAlgebra.approximateUnit` is an
  increasing approximate unit.

-/

variable {A : Type*} [NonUnitalCStarAlgebra A]

local notation "ŌÉ‚āô" => quasispectrum

local notation "ŌÉ" => spectrum

open Unitization NNReal CStarAlgebra

variable [PartialOrder A] [StarOrderedRing A]

set_option backward.isDefEq.respectTransparency false in

lemma CFC.monotoneOn_one_sub_one_add_inv :
    MonotoneOn (cfc‚āô (fun x : ‚ĄĚ‚Č•0 ‚Ü¶ 1 - (1 + x)‚ĀĽ¬Ļ)) (Set.Ici (0 : A)) := by
  intro a ha b hb hab
  simp only [Set.mem_Ici] at ha hb
  rw [‚Üź inr_le_iff .., nnreal_cfc‚āô_eq_cfc_inr a _, nnreal_cfc‚āô_eq_cfc_inr b _]
  rw [‚Üź inr_le_iff a b (.of_nonneg ha) (.of_nonneg hb)] at hab
  rw [‚Üź inr_nonneg_iff] at ha hb
  have h_cfc_one_sub (c : A‚Āļ¬Ļ) (hc : 0 ‚Č§ c := by cfc_tac) :
      cfc (fun x : ‚ĄĚ‚Č•0 ‚Ü¶ 1 - (1 + x)‚ĀĽ¬Ļ) c = 1 - cfc (¬∑‚ĀĽ¬Ļ : ‚ĄĚ‚Č•0 ‚Üí ‚ĄĚ‚Č•0) (1 + c) := by
    rw [cfc_tsub _ _ _ (fun x _ ‚Ü¶ by simp) (hg := by fun_prop (disch := intro _ _; positivity)),
      cfc_const_one ‚ĄĚ‚Č•0 c, cfc_comp' (¬∑‚ĀĽ¬Ļ) (1 + ¬∑) c ?_, cfc_add .., cfc_const_one ‚ĄĚ‚Č•0 c,
      cfc_id' ‚ĄĚ‚Č•0 c]
    exact continuousOn_id.inv‚āÄ (Set.forall_mem_image.mpr fun x _ ‚Ü¶ by dsimp only [id]; positivity)
  rw [h_cfc_one_sub (a : A‚Āļ¬Ļ), h_cfc_one_sub (b : A‚Āļ¬Ļ)]
  gcongr
  rw [‚Üź CFC.rpow_neg_one_eq_cfc_inv, ‚Üź CFC.rpow_neg_one_eq_cfc_inv]
  exact rpow_neg_one_le_rpow_neg_one (by gcongr)

lemma CFC.monotoneOn_one_sub_one_add_inv_real :
    MonotoneOn (cfc‚āô (fun x : ‚ĄĚ => 1 - (1 + x)‚ĀĽ¬Ļ)) (Set.Ici (0 : A)) := by
  intro a (ha : 0 ‚Č§ a) b (hb : 0 ‚Č§ b) hab
  calc _ = cfc‚āô (fun x : ‚ĄĚ‚Č•0 => 1 - (1 + x)‚ĀĽ¬Ļ) a := by
          rw [cfc‚āô_nnreal_eq_real _ _ ha]
          refine cfc‚āô_congr ?_
          intro x hx
          have hx' : 0 ‚Č§ x := by grind
          simp [hx']
    _ ‚Č§ cfc‚āô (fun x : ‚ĄĚ‚Č•0 => 1 - (1 + x)‚ĀĽ¬Ļ) b :=
          CFC.monotoneOn_one_sub_one_add_inv ha hb hab
    _ = cfc‚āô (fun x : ‚ĄĚ => 1 - (1 + x)‚ĀĽ¬Ļ) b := by
          rw [cfc‚āô_nnreal_eq_real _ _ hb]
          refine cfc‚āô_congr ?_
          intro x hx
          have hx' : 0 ‚Č§ x := by grind
          simp [hx']

lemma Set.InvOn.one_sub_one_add_inv : Set.InvOn (fun x ‚Ü¶ 1 - (1 + x)‚ĀĽ¬Ļ) (fun x ‚Ü¶ x * (1 - x)‚ĀĽ¬Ļ)
    {x : ‚ĄĚ‚Č•0 | x < 1} {x : ‚ĄĚ‚Č•0 | x < 1} := by
  have : (fun x : ‚ĄĚ‚Č•0 ‚Ü¶ x * (1 + x)‚ĀĽ¬Ļ) = fun x ‚Ü¶ 1 - (1 + x)‚ĀĽ¬Ļ := by
    ext x : 1
    simp [field, mul_tsub]
  rw [‚Üź this]
  constructor <;> intro x (hx : x < 1)
  ¬∑ have : 0 < 1 - x := tsub_pos_of_lt hx
    simp [field, tsub_add_cancel_of_le hx.le]
  ¬∑ simp [mul_assoc, ‚Üź mul_inv, mul_tsub]
    field_simp
    simp

lemma norm_cfc‚āô_one_sub_one_add_inv_lt_one (a : A) :
    ‚ÄĖcfc‚āô (fun x : ‚ĄĚ‚Č•0 ‚Ü¶ 1 - (1 + x)‚ĀĽ¬Ļ) a‚ÄĖ < 1 :=
  nnnorm_cfc‚āô_nnreal_lt fun x _ ‚Ü¶ tsub_lt_self zero_lt_one (by positivity)

lemma CStarAlgebra.directedOn_nonneg_ball :
    DirectedOn (¬∑ ‚Č§ ¬∑) ({x : A | 0 ‚Č§ x} ‚ą© Metric.ball 0 1) := by
  let f : ‚ĄĚ‚Č•0 ‚Üí ‚ĄĚ‚Č•0 := fun x => 1 - (1 + x)‚ĀĽ¬Ļ
  let g : ‚ĄĚ‚Č•0 ‚Üí ‚ĄĚ‚Č•0 := fun x => x * (1 - x)‚ĀĽ¬Ļ
  suffices ‚ąÄ a b : A, 0 ‚Č§ a ‚Üí 0 ‚Č§ b ‚Üí ‚ÄĖa‚ÄĖ < 1 ‚Üí ‚ÄĖb‚ÄĖ < 1 ‚Üí
      a ‚Č§ cfc‚āô f (cfc‚āô g a + cfc‚āô g b) by
    rintro a ‚ü®(ha‚āĀ : 0 ‚Č§ a), ha‚āā‚ü© b ‚ü®(hb‚āĀ : 0 ‚Č§ b), hb‚āā‚ü©
    simp only [Metric.mem_ball, dist_zero_right] at ha‚āā hb‚āā
    refine ‚ü®cfc‚āô f (cfc‚āô g a + cfc‚āô g b), ‚ü®by simp, ?_‚ü©, ?_, ?_‚ü©
    ¬∑ simpa only [Metric.mem_ball, dist_zero_right] using norm_cfc‚āô_one_sub_one_add_inv_lt_one _
    ¬∑ exact this a b ha‚āĀ hb‚āĀ ha‚āā hb‚āā
    ¬∑ exact add_comm (cfc‚āô g a) (cfc‚āô g b) ‚Ėł this b a hb‚āĀ ha‚āĀ hb‚āā ha‚āā
  rintro a b ha‚āĀ - ha‚āā -
  calc
    a = cfc‚āô (f ‚ąė g) a := by
      conv_lhs => rw [‚Üź cfc‚āô_id ‚ĄĚ‚Č•0 a]
      refine cfc‚āô_congr (Set.InvOn.one_sub_one_add_inv.1.eqOn.symm.mono fun x hx ‚Ü¶ ?_)
      exact lt_of_le_of_lt (le_nnnorm_of_mem_quasispectrum hx) ha‚āā
    _ = cfc‚āô f (cfc‚āô g a) := by
      rw [cfc‚āô_comp f g a ?_ (by simp [f, tsub_self]) ?_ (by simp [g]) ha‚āĀ]
      ¬∑ fun_prop (disch := intro _ _; positivity)
      ¬∑ have (x) (hx : x ‚ąą ŌÉ‚āô ‚ĄĚ‚Č•0 a) : 1 - x ‚Č† 0 := by
          refine tsub_pos_of_lt ?_ |>.ne'
          exact lt_of_le_of_lt (le_nnnorm_of_mem_quasispectrum hx) ha‚āā
        fun_prop (disch := assumption)
    _ ‚Č§ cfc‚āô f (cfc‚āô g a + cfc‚āô g b) := by
      have hab' : cfc‚āô g a ‚Č§ cfc‚āô g a + cfc‚āô g b := le_add_of_nonneg_right cfc‚āô_nonneg_of_predicate
      exact CFC.monotoneOn_one_sub_one_add_inv cfc‚āô_nonneg_of_predicate
        (cfc‚āô_nonneg_of_predicate.trans hab') hab'

section ApproximateUnit

open Metric Filter Topology

structure Filter.IsIncreasingApproximateUnit (l : Filter A) : Prop extends l.IsApproximateUnit where
  eventually_nonneg : ‚ąÄŠ∂† x in l, 0 ‚Č§ x
  eventually_norm : ‚ąÄŠ∂† x in l, ‚ÄĖx‚ÄĖ ‚Č§ 1

namespace Filter.IsIncreasingApproximateUnit

omit [StarOrderedRing A] in

lemma eventually_nnnorm {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    ‚ąÄŠ∂† x in l, ‚ÄĖx‚ÄĖ‚āä ‚Č§ 1 :=
  hl.eventually_norm

lemma eventually_isSelfAdjoint {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    ‚ąÄŠ∂† x in l, IsSelfAdjoint x :=
  hl.eventually_nonneg.mp <| .of_forall fun _ ‚Ü¶ IsSelfAdjoint.of_nonneg

lemma eventually_star_eq {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    ‚ąÄŠ∂† x in l, star x = x :=
  hl.eventually_isSelfAdjoint.mp <| .of_forall fun _ ‚Ü¶ IsSelfAdjoint.star_eq

end Filter.IsIncreasingApproximateUnit


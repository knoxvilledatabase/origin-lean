lemma tendsto_mul_right_of_forall_nonneg_tendsto {l : Filter A}
    (h : ‚ąÄ m, 0 ‚Č§ m ‚Üí ‚ÄĖm‚ÄĖ < 1 ‚Üí Tendsto (¬∑ * m) l (ūĚďĚ m)) (m : A) :
    Tendsto (¬∑ * m) l (ūĚďĚ m) := by
  obtain ‚ü®n, c, x, rfl‚ü© := mem_span_set'.mp <| by
    change m ‚ąą span ‚Ąā ({x | 0 ‚Č§ x} ‚ą© ball 0 1)
    simp [span_nonneg_inter_unitBall]
  simp_rw [Finset.mul_sum]
  refine tendsto_finset_sum _ fun i _ ‚Ü¶ ?_
  simp_rw [mul_smul_comm]
  exact tendsto_const_nhds.smul <| h (x i) (x i).2.1 <| by simpa using (x i).2.2

omit [PartialOrder A] in

lemma tendsto_mul_left_iff_tendsto_mul_right {l : Filter A} (hl : ‚ąÄŠ∂† x in l, IsSelfAdjoint x) :
    (‚ąÄ m, Tendsto (m * ¬∑) l (ūĚďĚ m)) ‚ÜĒ (‚ąÄ m, Tendsto (¬∑ * m) l (ūĚďĚ m)) := by
  refine ‚ü®fun h m ‚Ü¶ ?_, fun h m ‚Ü¶ ?_‚ü©
  all_goals
    apply (star_star m ‚Ėł (continuous_star.tendsto _ |>.comp <| h (star m))).congr'
    filter_upwards [hl] with x hx
    simp [hx.star_eq]

variable (A)

lemma isBasis_nonneg_sections :
    IsBasis (fun x : A ‚Ü¶ 0 ‚Č§ x ‚ąß ‚ÄĖx‚ÄĖ < 1) ({x | ¬∑ ‚Č§ x}) where
  nonempty := ‚ü®0, by simp‚ü©
  inter {x y} hx hy := by
    peel directedOn_nonneg_ball x (by simpa) y (by simpa) with z hz
    exact ‚ü®by simpa using hz.1, fun a ha ‚Ü¶ ‚ü®hz.2.1.trans ha, hz.2.2.trans ha‚ü©‚ü©

def approximateUnit : Filter A :=
  (isBasis_nonneg_sections A).filter ‚äď ūĚďü (closedBall 0 1)

lemma hasBasis_approximateUnit :
    (approximateUnit A).HasBasis (fun x : A ‚Ü¶ 0 ‚Č§ x ‚ąß ‚ÄĖx‚ÄĖ < 1) ({x | ¬∑ ‚Č§ x} ‚ą© closedBall 0 1) :=
  isBasis_nonneg_sections A |>.hasBasis.inf_principal (closedBall 0 1)

lemma nnnorm_sub_mul_self_le {A : Type*} [CStarAlgebra A] [PartialOrder A] [StarOrderedRing A]
    {x y : A} (z : A) (hx‚āÄ : 0 ‚Č§ x) (hy : y ‚ąą Set.Icc x 1) {c : ‚ĄĚ‚Č•0}
    (h : ‚ÄĖstar z * (1 - x) * z‚ÄĖ‚āä ‚Č§ c ^ 2) :
    ‚ÄĖz - y * z‚ÄĖ‚āä ‚Č§ c := by
  nth_rw 1 [‚Üź one_mul z]
  rw [‚Üź sqrt_sq c, le_sqrt_iff_sq_le, ‚Üź sub_mul, sq, ‚Üź CStarRing.nnnorm_star_mul_self]
  simp only [star_mul, star_sub, star_one]
  have hy‚āÄ : y ‚ąą Set.Icc 0 1 := ‚ü®hx‚āÄ.trans hy.1, hy.2‚ü©
  have hy' : 1 - y ‚ąą Set.Icc 0 1 := Set.sub_mem_Icc_zero_iff_right.mpr hy‚āÄ
  rw [hy‚āÄ.1.star_eq, ‚Üź mul_assoc, mul_assoc (star _), ‚Üź sq]
  refine nnnorm_le_nnnorm_of_nonneg_of_le (star_left_conjugate_nonneg (pow_nonneg hy'.1 2) _) ?_
    |>.trans h
  refine star_left_conjugate_le_conjugate ?_ _
  trans (1 - y)
  ¬∑ simpa using pow_antitone hy'.1 hy'.2 one_le_two
  ¬∑ gcongr
    exact hy.1

lemma norm_sub_mul_self_le {A : Type*} [CStarAlgebra A] [PartialOrder A] [StarOrderedRing A]
    {x y : A} (z : A) (hx‚āÄ : 0 ‚Č§ x) (hy : y ‚ąą Set.Icc x 1)
    {c : ‚ĄĚ} (hc : 0 ‚Č§ c) (h : ‚ÄĖstar z * (1 - x) * z‚ÄĖ ‚Č§ c ^ 2) :
    ‚ÄĖz - y * z‚ÄĖ ‚Č§ c :=
  nnnorm_sub_mul_self_le z hx‚āÄ hy h (c := ‚ü®c, hc‚ü©)

variable {A} in

lemma norm_sub_mul_self_le_of_inr {x y : A} (z : A) (hx‚āÄ : 0 ‚Č§ x) (hxy : x ‚Č§ y) (hy‚āĀ : ‚ÄĖy‚ÄĖ ‚Č§ 1)
    {c : ‚ĄĚ} (hc : 0 ‚Č§ c) (h : ‚ÄĖstar (z : A‚Āļ¬Ļ) * (1 - x) * z‚ÄĖ ‚Č§ c ^ 2) :
    ‚ÄĖz - y * z‚ÄĖ ‚Č§ c := by
  rw [‚Üź norm_inr (ūĚēú := ‚Ąā), inr_sub, inr_mul]
  refine norm_sub_mul_self_le _ ?_ ?_ hc h
  ¬∑ rwa [inr_nonneg_iff]
  ¬∑ have hy := hx‚āÄ.trans hxy
    rw [Set.mem_Icc, inr_le_iff _ _ hx‚āÄ.isSelfAdjoint hy.isSelfAdjoint,
      ‚Üź norm_le_one_iff_of_nonneg _, norm_inr]
    exact ‚ü®hxy, hy‚āĀ‚ü©


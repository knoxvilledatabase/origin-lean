variable {A} in

private lemma tendsto_mul_right_approximateUnit (m : A) :
    Tendsto (¬∑ * m) (approximateUnit A) (ūĚďĚ m) := by
  refine tendsto_mul_right_of_forall_nonneg_tendsto (fun m hm‚āĀ hm‚āā ‚Ü¶ ?_) m
  rw [(hasBasis_approximateUnit A).tendsto_iff nhds_basis_closedBall]
  intro őĶ hőĶ
  lift őĶ to ‚ĄĚ‚Č•0 using hőĶ.le
  rw [coe_pos] at hőĶ
  refine ‚ü®cfc‚āô (fun y : ‚ĄĚ‚Č•0 ‚Ü¶ 1 - (1 + y)‚ĀĽ¬Ļ) (őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ m),
    ‚ü®cfc‚āô_nonneg_of_predicate, norm_cfc‚āô_one_sub_one_add_inv_lt_one (őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ m)‚ü©, ?_‚ü©
  rintro x ‚ü®(hx‚āĀ : _ ‚Č§ x), hx‚āā‚ü©
  simp only [mem_closedBall, dist_eq_norm', zero_sub, norm_neg] at hx‚āā ‚äĘ
  rw [‚Üź coe_nnnorm, coe_le_coe]
  have hx‚āÄ : 0 ‚Č§ x := cfc‚āô_nonneg_of_predicate.trans hx‚āĀ
  rw [‚Üź inr_le_iff _ _ (.of_nonneg cfc‚āô_nonneg_of_predicate) (.of_nonneg hx‚āÄ),
    nnreal_cfc‚āô_eq_cfc_inr _ _ (by simp [tsub_self]), inr_smul] at hx‚āĀ
  rw [‚Üź norm_inr (ūĚēú := ‚Ąā)] at hm‚āā hx‚āā
  rw [‚Üź inr_nonneg_iff] at hx‚āÄ hm‚āĀ
  rw [‚Üź nnnorm_inr (ūĚēú := ‚Ąā), inr_sub, inr_mul]
  generalize (x : A‚Āļ¬Ļ) = x, (m : A‚Āļ¬Ļ) = m at *
  set g : ‚ĄĚ‚Č•0 ‚Üí ‚ĄĚ‚Č•0 := fun y ‚Ü¶ 1 - (1 + y)‚ĀĽ¬Ļ
  have hg : Continuous g := by
    rw [‚Üź continuousOn_univ]
    fun_prop (disch := intro _ _; positivity)
  have hg' : ContinuousOn (fun y ‚Ü¶ (1 + őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ y)‚ĀĽ¬Ļ) (spectrum ‚ĄĚ‚Č•0 m) :=
    ContinuousOn.inv‚āÄ (by fun_prop) fun _ _ ‚Ü¶ by positivity
  have hx : x ‚ąą Set.Icc 0 1 := mem_Icc_iff_norm_le_one.mpr ‚ü®hx‚āÄ, hx‚āā‚ü©
  have hx' : x ‚ąą Set.Icc _ 1 := ‚ü®hx‚āĀ, hx.2‚ü©
  refine nnnorm_sub_mul_self_le m cfc_nonneg_of_predicate hx' ?_
  suffices star m * (1 - cfc g (őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ m)) * m =
      cfc (fun y : ‚ĄĚ‚Č•0 ‚Ü¶ y * (1 + őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ y)‚ĀĽ¬Ļ * y) m by
    rw [this]
    refine nnnorm_cfc_nnreal_le fun y hy ‚Ü¶ ?_
    calc
      y * (1 + őĶ‚ĀĽ¬Ļ ^ 2 ‚ÄĘ y)‚ĀĽ¬Ļ * y = y * őĶ ^ 2 * (y / (őĶ ^ 2 + y)) := by simp [field]
      _ ‚Č§ őĶ ^ 2 * 1 := by
        gcongr
        ¬∑ refine mul_le_of_le_one_left (zero_le _) ?_
          have hm' := hm‚āā.le
          rw [norm_le_one_iff_of_nonneg m hm‚āĀ, ‚Üź cfc_id' ‚ĄĚ‚Č•0 m, ‚Üź cfc_one (R := ‚ĄĚ‚Č•0) m,
            cfc_nnreal_le_iff _ _ _ (QuasispectrumRestricts.nnreal_of_nonneg hm‚āĀ)] at hm'
          exact hm' y hy
        ¬∑ exact div_le_one (by positivity) |>.mpr le_add_self
      _ = őĶ ^ 2 := mul_one _
  rw [cfc_mul _ _ m (continuousOn_id' _ |>.fun_mul hg') (continuousOn_id' _),
    cfc_mul _ _ m (continuousOn_id' _) hg', cfc_id' .., hm‚āĀ.star_eq]
  congr
  rw [‚Üź cfc_one (R := ‚ĄĚ‚Č•0) m, ‚Üź cfc_comp_smul _ _ _ hg.continuousOn hm‚āĀ,
    ‚Üź cfc_tsub _ _ m (by simp [g]) hm‚āĀ (by fun_prop) (Continuous.continuousOn <| by fun_prop)]
  refine cfc_congr (fun y _ ‚Ü¶ ?_)
  simp [g, tsub_tsub_cancel_of_le]

lemma increasingApproximateUnit :
    IsIncreasingApproximateUnit (approximateUnit A) where
  tendsto_mul_left := by
    rw [tendsto_mul_left_iff_tendsto_mul_right]
    ¬∑ exact tendsto_mul_right_approximateUnit
    ¬∑ rw [(hasBasis_approximateUnit A).eventually_iff]
      peel (hasBasis_approximateUnit A).ex_mem with x hx
      exact ‚ü®hx, fun y hy ‚Ü¶ (hx.1.trans hy.1).isSelfAdjoint‚ü©
  tendsto_mul_right := tendsto_mul_right_approximateUnit
  eventually_nonneg := .filter_mono inf_le_left <|
    (isBasis_nonneg_sections A).hasBasis.eventually_iff.mpr ‚ü®0, by simp‚ü©
  eventually_norm := .filter_mono inf_le_right <| by simp
  neBot := hasBasis_approximateUnit A |>.neBot_iff.mpr
    fun hx ‚Ü¶ ‚ü®_, ‚ü®le_rfl, by simpa using hx.2.le‚ü©‚ü©

end CStarAlgebra

end ApproximateUnit

    {M : Type*} [TopologicalSpace M] [ChartedSpace H M] (_x : M) : Type u := E

def NormedSpace.fromTangentSpace (v : E) : TangentSpace 𝓘(𝕜, E) v ≃L[𝕜] E where
  toFun v := v
  invFun v := v
  map_add' := by simp
  map_smul' := by simp

abbrev TangentBundle := Bundle.TotalSpace E (TangentSpace I : M → Type _)


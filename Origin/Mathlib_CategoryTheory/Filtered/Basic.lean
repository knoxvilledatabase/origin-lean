  exact РЪеs, ts РЅФ kРѓЂt, ts РЅФ kРѓѓt, by simp only [Category.assoc, ht],
    by simp only [Category.assoc, hs]РЪЕ

theorem of_left_adjoint {L : C РЦц D} {R : D РЦц C} (h : L РіБ R) : IsCofilteredOrEmpty D :=
  { cone_objs := fun X Y =>
      РЪеL.obj (min (R.obj X) (R.obj Y)), (h.homEquiv _ X).symm (minToLeft _ _),
        (h.homEquiv _ Y).symm (minToRight _ _), РЪеРЪЕРЪЕ
    cone_maps := fun X Y f g =>
      РЪеL.obj (eq (R.map f) (R.map g)), (h.homEquiv _ _).symm (eqHom _ _), by
        rw [Рєљ h.homEquiv_naturality_right_symm, Рєљ h.homEquiv_naturality_right_symm, eq_condition]РЪЕ }

theorem of_isLeftAdjoint (L : C РЦц D) [L.IsLeftAdjoint] : IsCofilteredOrEmpty D :=
  of_left_adjoint (Adjunction.ofIsLeftAdjoint L)

theorem of_equivalence (h : C РЅї D) : IsCofilteredOrEmpty D :=
  of_left_adjoint h.toAdjunction

noncomputable def inf : C :=
  (inf_exists O H).choose

noncomputable def infTo {X : C} (m : X Рѕѕ O) : inf O H РЪХ X :=
  (inf_exists O H).choose_spec.choose m

theorem infTo_commutes {X Y : C} (mX : X Рѕѕ O) (mY : Y Рѕѕ O) {f : X РЪХ Y}
    (mf : (РЪеX, Y, mX, mY, fРЪЕ : ╬Б' (X Y : C) (_ : X Рѕѕ O) (_ : Y Рѕѕ O), X РЪХ Y) Рѕѕ H) :
    infTo O H mX РЅФ f = infTo O H mY :=
  (inf_exists O H).choose_spec.choose_spec mX mY mf

theorem cone_nonempty (F : J РЦц C) : Nonempty (Cone F) := by
  classical
  let O := Finset.univ.image F.obj
  let H : Finset (╬Б' (X Y : C) (_ : X Рѕѕ O) (_ : Y Рѕѕ O), X РЪХ Y) :=
    Finset.univ.biUnion fun X : J =>
      Finset.univ.biUnion fun Y : J =>
        Finset.univ.image fun f : X РЪХ Y => РЪеF.obj X, F.obj Y, by simp [O], by simp [O], F.map fРЪЕ
  obtain РЪеZ, f, wРЪЕ := inf_exists O H
  refine РЪеРЪеZ, РЪеfun X => f (by simp [O]), ?_РЪЕРЪЕРЪЕ
  intro j j' g
  dsimp
  simp only [Category.id_comp]
  symm
  apply w
  simp only [O, H, Finset.mem_biUnion, Finset.mem_univ, Finset.mem_image,
    PSigma.mk.injEq, true_and, exists_and_left]
  exact РЪеj, rfl, j', g, by simpРЪЕ

noncomputable def cone (F : J РЦц C) : Cone F :=
  (cone_nonempty F).some

theorem of_left_adjoint {L : C РЦц D} {R : D РЦц C} (h : L РіБ R) : IsCofiltered D :=
  { IsCofilteredOrEmpty.of_left_adjoint h with
    nonempty := IsCofiltered.nonempty.map L.obj }

theorem of_isLeftAdjoint (L : C РЦц D) [L.IsLeftAdjoint] : IsCofiltered D :=
  of_left_adjoint (Adjunction.ofIsLeftAdjoint L)

theorem of_equivalence (h : C РЅї D) : IsCofiltered D :=
  of_left_adjoint h.toAdjunction

lemma iff_of_equivalence (e : C РЅї D) : IsCofiltered C Рєћ IsCofiltered D :=
  РЪеfun _ Рєд .of_equivalence e, fun _ Рєд .of_equivalence e.symmРЪЕ

lemma wideCospan [IsCofilteredOrEmpty C]
    {I : Type*} [Finite I] {i : C} {j : I Рєњ C} (f : Рѕђ x, j x РЪХ i) :
    РѕЃ k fki, РѕЃ g : Рѕђ x, k РЪХ j x, Рѕђ x, g x РЅФ f x = fki := by
  have : IsCofiltered C := { nonempty := РЪеiРЪЕ }
  classical
  cases nonempty_fintype I
  obtain РЪеk, fk, hkРЪЕ := IsCofiltered.inf_exists (insert i (Finset.univ.image j))
    (Finset.univ.image fun x Рєд РЪеj x, i, by simp, by simp, f xРЪЕ)
  exact РЪеk, _, _, fun x Рєд hk _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ _))РЪЕ

theorem of_hasFiniteLimits [HasFiniteLimits C] : IsCofiltered C :=
  of_cone_nonempty.{v} C fun F => РЪеlimit.cone FРЪЕ

theorem of_isInitial {X : C} (h : IsInitial X) : IsCofiltered C :=
  of_cone_nonempty.{v} _ fun {_} _ _ _ => РЪеРЪеX, РЪеfun _ => h.to _, fun _ _ _ => h.hom_ext _ _РЪЕРЪЕРЪЕ

theorem iff_cone_nonempty : IsCofiltered C Рєћ
    Рѕђ {J : Type w} [SmallCategory J] [FinCategory J] (F : J РЦц C), Nonempty (Cone F) :=
  РЪеfun _ _ _ _ F => cone_nonempty F, of_cone_nonempty CРЪЕ


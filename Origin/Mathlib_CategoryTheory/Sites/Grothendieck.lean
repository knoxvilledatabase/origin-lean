  sieves X := {S | ∀ {Y : C} (f : Y ⟶ X), ∃ (Z : _) (g : Z ⟶ Y), S (g ≫ f)}
  top_mem' _ Y _ := ⟨Y, 𝟙 Y, ⟨⟩⟩

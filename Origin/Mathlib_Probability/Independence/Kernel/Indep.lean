theorem Indep.indepSet_of_measurableSet {m‚āĀ m‚āā _ : MeasurableSpace ő©} {őļ : Kernel őĪ ő©}
    {őľ : Measure őĪ}
    (h_indep : Indep m‚āĀ m‚āā őļ őľ) {s t : Set ő©} (hs : MeasurableSet[m‚āĀ] s)
    (ht : MeasurableSet[m‚āā] t) :
    IndepSet s t őļ őľ := by
  refine fun s' t' hs' ht' => h_indep s' t' ?_ ?_
  ¬∑ induction s', hs' using generateFrom_induction with
    | hC t ht => exact ht ‚Ėł hs
    | empty => exact @MeasurableSet.empty _ m‚āĀ
    | compl u _ hu => exact hu.compl
    | iUnion f _ hf => exact .iUnion hf
  ¬∑ induction t', ht' using generateFrom_induction with
    | hC s hs => exact hs ‚Ėł ht
    | empty => exact @MeasurableSet.empty _ m‚āā
    | compl u _ hu => exact hu.compl
    | iUnion f _ hf => exact .iUnion hf

theorem indep_iff_forall_indepSet (m‚āĀ m‚āā : MeasurableSpace ő©) {_m0 : MeasurableSpace ő©}

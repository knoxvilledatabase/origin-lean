theorem indepSet_iff_indepSets_singleton {m0 : MeasurableSpace ő©} (hs_meas : MeasurableSet s)
    (ht_meas : MeasurableSet t) (őļ : Kernel őĪ ő©) (őľ : Measure őĪ)

theorem iIndepSet.meas_biInter {_mő© : MeasurableSpace ő©} {őļ : Kernel őĪ ő©}
    {őľ : Measure őĪ} {f : őĻ ‚Üí Set ő©} (h : iIndepSet f őļ őľ) (s : Finset őĻ) :
    ‚ąÄŠĶź a ‚ąāőľ, őļ a (‚čā i ‚ąą s, f i) = ‚ąŹ i ‚ąą s, őļ a (f i) :=
  iIndep.iIndepSets (fun _ ‚Ü¶ rfl) h _ (by simp)


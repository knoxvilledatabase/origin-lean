  ‚ü®Indep.indepSets, fun h =>
    IndepSets.indep
      (generateFrom_le fun u hu => by rwa [Set.mem_singleton_iff.mp hu])
      (generateFrom_le fun u hu => by rwa [Set.mem_singleton_iff.mp hu])
      (IsPiSystem.singleton s) (IsPiSystem.singleton t) rfl rfl h‚ü©

theorem indepSet_iff_measure_inter_eq_mul {_m0 : MeasurableSpace ő©} (hs_meas : MeasurableSet s)
    (ht_meas : MeasurableSet t) (őļ : Kernel őĪ ő©) (őľ : Measure őĪ)
    [IsZeroOrMarkovKernel őļ] :

theorem iIndepSets.iIndepSet_of_mem {_mő© : MeasurableSpace ő©} {őļ : Kernel őĪ ő©}
    {őľ : Measure őĪ} {ŌÄ : őĻ ‚Üí Set (Set ő©)} {f : őĻ ‚Üí Set ő©}
    (hfŌÄ : ‚ąÄ i, f i ‚ąą ŌÄ i) (hf : ‚ąÄ i, MeasurableSet (f i)) (hŌÄ : iIndepSets ŌÄ őļ őľ) :

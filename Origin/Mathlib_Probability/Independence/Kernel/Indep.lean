    {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} {s1 s2 : Set (Set ő©)}
    (h_indep : Indep (generateFrom s1) (generateFrom s2) őļ őľ) :
    IndepSets s1 s2 őļ őľ :=
  fun t1 t2 ht1 ht2 =>
  h_indep t1 t2 (measurableSet_generateFrom ht1) (measurableSet_generateFrom ht2)

theorem IndepSets.indep_aux {m‚āā m : MeasurableSpace ő©}
    {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} [IsZeroOrMarkovKernel őļ] {p1 p2 : Set (Set ő©)} (h2 : m‚āā ‚Č§ m)
    (hp2 : IsPiSystem p2) (hpm2 : m‚āā = generateFrom p2) (hyp : IndepSets p1 p2 őļ őľ) {t1 t2 : Set ő©}
    (ht1 : t1 ‚ąą p1) (ht1m : MeasurableSet[m] t1) (ht2m : MeasurableSet[m‚āā] t2) :
    ‚ąÄŠĶź a ‚ąāőľ, őļ a (t1 ‚ą© t2) = őļ a t1 * őļ a t2 := by
  rcases eq_zero_or_isMarkovKernel őļ with rfl | h
  ¬∑ simp
  induction t2, ht2m using induction_on_inter hpm2 hp2 with
  | empty => simp
  | basic u hu => exact hyp t1 u ht1 hu
  | compl u hu ihu =>
    filter_upwards [ihu] with a ha
    rw [‚Üź Set.diff_eq, ‚Üź Set.diff_self_inter,
      measure_diff inter_subset_left (ht1m.inter (h2 _ hu)).nullMeasurableSet (measure_ne_top _ _),
      ha, measure_compl (h2 _ hu) (measure_ne_top _ _), measure_univ, ENNReal.mul_sub, mul_one]
    exact fun _ _ ‚Ü¶ measure_ne_top _ _
  | iUnion f hfd hfm ihf =>
    rw [‚Üź ae_all_iff] at ihf
    filter_upwards [ihf] with a ha
    rw [inter_iUnion, measure_iUnion, measure_iUnion hfd fun i ‚Ü¶ h2 _ (hfm i)]
    ¬∑ simp only [ENNReal.tsum_mul_left, ha]
    ¬∑ exact hfd.mono fun i j h ‚Ü¶ (h.inter_left' _).inter_right' _
    ¬∑ exact fun i ‚Ü¶ .inter ht1m (h2 _ <| hfm i)

theorem IndepSets.indep {m1 m2 m : MeasurableSpace ő©} {őļ : Kernel őĪ ő©} {őľ : Measure őĪ}
    [IsZeroOrMarkovKernel őļ] {p1 p2 : Set (Set ő©)} (h1 : m1 ‚Č§ m) (h2 : m2 ‚Č§ m) (hp1 : IsPiSystem p1)
    (hp2 : IsPiSystem p2) (hpm1 : m1 = generateFrom p1) (hpm2 : m2 = generateFrom p2)
    (hyp : IndepSets p1 p2 őļ őľ) :
    Indep m1 m2 őļ őľ := by
  rcases eq_zero_or_isMarkovKernel őļ with rfl | h
  ¬∑ simp
  intro t1 t2 ht1 ht2
  induction t1, ht1 using induction_on_inter hpm1 hp1 with
  | empty =>
    simp only [Set.empty_inter, measure_empty, zero_mul, Filter.eventually_true]
  | basic t ht =>
    refine IndepSets.indep_aux h2 hp2 hpm2 hyp ht (h1 _ ?_) ht2
    rw [hpm1]
    exact measurableSet_generateFrom ht
  | compl t ht iht =>
    filter_upwards [iht] with a ha
    have : tŠ∂ú ‚ą© t2 = t2 \ (t ‚ą© t2) := by
      rw [Set.inter_comm t, Set.diff_self_inter, Set.diff_eq_compl_inter]
    rw [this, Set.inter_comm t t2,
      measure_diff Set.inter_subset_left ((h2 _ ht2).inter (h1 _ ht)).nullMeasurableSet
        (measure_ne_top (őļ a) _),
      Set.inter_comm, ha, measure_compl (h1 _ ht) (measure_ne_top (őļ a) t), measure_univ,
      mul_comm (1 - őļ a t), ENNReal.mul_sub (fun _ _ ‚Ü¶ measure_ne_top (őļ a) _), mul_one, mul_comm]
  | iUnion f hf_disj hf_meas h =>
    rw [‚Üź ae_all_iff] at h
    filter_upwards [h] with a ha
    rw [Set.inter_comm, Set.inter_iUnion, measure_iUnion]
    ¬∑ rw [measure_iUnion hf_disj (fun i ‚Ü¶ h1 _ (hf_meas i))]
      rw [‚Üź ENNReal.tsum_mul_right]
      congr 1 with i
      rw [Set.inter_comm t2, ha i]
    ¬∑ intro i j hij
      rw [Function.onFun, Set.inter_comm t2, Set.inter_comm t2]
      exact Disjoint.inter_left _ (Disjoint.inter_right _ (hf_disj hij))
    ¬∑ exact fun i ‚Ü¶ (h2 _ ht2).inter (h1 _ (hf_meas i))

theorem IndepSets.indep' {_mő© : MeasurableSpace ő©}
    {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} [IsZeroOrMarkovKernel őļ]
    {p1 p2 : Set (Set ő©)} (hp1m : ‚ąÄ s ‚ąą p1, MeasurableSet s) (hp2m : ‚ąÄ s ‚ąą p2, MeasurableSet s)
    (hp1 : IsPiSystem p1) (hp2 : IsPiSystem p2) (hyp : IndepSets p1 p2 őļ őľ) :
    Indep (generateFrom p1) (generateFrom p2) őļ őľ :=
  hyp.indep (generateFrom_le hp1m) (generateFrom_le hp2m) hp1 hp2 rfl rfl

theorem indepSets_piiUnionInter_of_disjoint {s : őĻ ‚Üí Set (Set ő©)}
    {S T : Set őĻ} (h_indep : iIndepSets s őļ őľ) (hST : Disjoint S T) :
    IndepSets (piiUnionInter s S) (piiUnionInter s T) őļ őľ := by
  rintro t1 t2 ‚ü®p1, hp1, f1, ht1_m, ht1_eq‚ü© ‚ü®p2, hp2, f2, ht2_m, ht2_eq‚ü©
  classical
  let g i := ite (i ‚ąą p1) (f1 i) Set.univ ‚ą© ite (i ‚ąą p2) (f2 i) Set.univ
  have h_P_inter : ‚ąÄŠĶź a ‚ąāőľ, őļ a (t1 ‚ą© t2) = ‚ąŹ n ‚ąą p1 ‚ą™ p2, őļ a (g n) := by
    have hgm : ‚ąÄ i ‚ąą p1 ‚ą™ p2, g i ‚ąą s i := by
      intro i hi_mem_union
      rw [Finset.mem_union] at hi_mem_union
      rcases hi_mem_union with hi1 | hi2
      ¬∑ have hi2 : i ‚ąČ p2 := fun hip2 => Set.disjoint_left.mp hST (hp1 hi1) (hp2 hip2)
        simp_rw [g, if_pos hi1, if_neg hi2, Set.inter_univ]
        exact ht1_m i hi1
      ¬∑ have hi1 : i ‚ąČ p1 := fun hip1 => Set.disjoint_right.mp hST (hp2 hi2) (hp1 hip1)
        simp_rw [g, if_neg hi1, if_pos hi2, Set.univ_inter]
        exact ht2_m i hi2
    have h_p1_inter_p2 :
      ((‚čā x ‚ąą p1, f1 x) ‚ą© ‚čā x ‚ąą p2, f2 x) =
        ‚čā i ‚ąą p1 ‚ą™ p2, ite (i ‚ąą p1) (f1 i) Set.univ ‚ą© ite (i ‚ąą p2) (f2 i) Set.univ := by
      ext1 x
      simp only [Set.mem_ite_univ_right, Set.mem_inter_iff, Set.mem_iInter, Finset.mem_union]
      exact
        ‚ü®fun h i _ => ‚ü®h.1 i, h.2 i‚ü©, fun h =>
          ‚ü®fun i hi => (h i (Or.inl hi)).1 hi, fun i hi => (h i (Or.inr hi)).2 hi‚ü©‚ü©
    filter_upwards [h_indep _ hgm] with a ha
    rw [ht1_eq, ht2_eq, h_p1_inter_p2, ‚Üź ha]
  filter_upwards [h_P_inter, h_indep p1 ht1_m, h_indep p2 ht2_m, h_indep.ae_isProbabilityMeasure]
    with a h_P_inter ha1 ha2 h'
  have h_őľg : ‚ąÄ n, őļ a (g n) = (ite (n ‚ąą p1) (őļ a (f1 n)) 1) * (ite (n ‚ąą p2) (őļ a (f2 n)) 1) := by
    intro n
    dsimp only [g]
    split_ifs with h1 h2
    ¬∑ exact absurd rfl (Set.disjoint_iff_forall_ne.mp hST (hp1 h1) (hp2 h2))
    all_goals simp only [measure_univ, one_mul, mul_one, Set.inter_univ, Set.univ_inter]
  simp_rw [h_P_inter, h_őľg, Finset.prod_mul_distrib,
    Finset.prod_ite_mem (p1 ‚ą™ p2) p1 (fun x ‚Ü¶ őļ a (f1 x)), Finset.union_inter_cancel_left,
    Finset.prod_ite_mem (p1 ‚ą™ p2) p2 (fun x => őļ a (f2 x)), Finset.union_inter_cancel_right, ht1_eq,
      ‚Üź ha1, ht2_eq, ‚Üź ha2]

theorem iIndepSet.indep_generateFrom_of_disjoint {s : őĻ ‚Üí Set ő©}
    (hsm : ‚ąÄ n, MeasurableSet (s n)) (hs : iIndepSet s őļ őľ) (S T : Set őĻ) (hST : Disjoint S T) :
    Indep (generateFrom { t | ‚ąÉ n ‚ąą S, s n = t }) (generateFrom { t | ‚ąÉ k ‚ąą T, s k = t }) őļ őľ := by
  classical
  rcases eq_or_ne őľ 0 with rfl | hőľ
  ¬∑ simp
  obtain ‚ü®ő∑, ő∑_eq, hő∑‚ü© : ‚ąÉ (ő∑ : Kernel őĪ ő©), őļ =ŠĶź[őľ] ő∑ ‚ąß IsMarkovKernel ő∑ :=
    exists_ae_eq_isMarkovKernel hs.ae_isProbabilityMeasure hőľ
  apply Indep.congr (Filter.EventuallyEq.symm ő∑_eq)
  rw [‚Üź generateFrom_piiUnionInter_singleton_left, ‚Üź generateFrom_piiUnionInter_singleton_left]
  refine
    IndepSets.indep'
      (fun t ht => generateFrom_piiUnionInter_le _ ?_ _ _ (measurableSet_generateFrom ht))
      (fun t ht => generateFrom_piiUnionInter_le _ ?_ _ _ (measurableSet_generateFrom ht)) ?_ ?_ ?_
  ¬∑ exact fun k => generateFrom_le fun t ht => (Set.mem_singleton_iff.1 ht).symm ‚Ėł hsm k
  ¬∑ exact fun k => generateFrom_le fun t ht => (Set.mem_singleton_iff.1 ht).symm ‚Ėł hsm k
  ¬∑ exact isPiSystem_piiUnionInter _ (fun k => IsPiSystem.singleton _) _
  ¬∑ exact isPiSystem_piiUnionInter _ (fun k => IsPiSystem.singleton _) _
  ¬∑ exact indepSets_piiUnionInter_of_disjoint (iIndep.iIndepSets (fun n => rfl) (hs.congr ő∑_eq)) hST

theorem indep_iSup_of_disjoint {m : őĻ ‚Üí MeasurableSpace ő©}
    (h_le : ‚ąÄ i, m i ‚Č§ _mő©) (h_indep : iIndep m őļ őľ) {S T : Set őĻ} (hST : Disjoint S T) :
    Indep (‚®Ü i ‚ąą S, m i) (‚®Ü i ‚ąą T, m i) őļ őľ := by
  classical
  rcases eq_or_ne őľ 0 with rfl | hőľ
  ¬∑ simp
  obtain ‚ü®ő∑, ő∑_eq, hő∑‚ü© : ‚ąÉ (ő∑ : Kernel őĪ ő©), őļ =ŠĶź[őľ] ő∑ ‚ąß IsMarkovKernel ő∑ :=
    exists_ae_eq_isMarkovKernel h_indep.ae_isProbabilityMeasure hőľ
  apply Indep.congr (Filter.EventuallyEq.symm ő∑_eq)
  refine
    IndepSets.indep (iSup‚āā_le fun i _ => h_le i) (iSup‚āā_le fun i _ => h_le i) ?_ ?_
      (generateFrom_piiUnionInter_measurableSet m S).symm
      (generateFrom_piiUnionInter_measurableSet m T).symm ?_
  ¬∑ exact isPiSystem_piiUnionInter _ (fun n => @isPiSystem_measurableSet ő© (m n)) _
  ¬∑ exact isPiSystem_piiUnionInter _ (fun n => @isPiSystem_measurableSet ő© (m n)) _
  ¬∑ exact indepSets_piiUnionInter_of_disjoint (h_indep.congr ő∑_eq) hST

theorem indep_iSup_of_directed_le {ő©} {m : őĻ ‚Üí MeasurableSpace ő©} {m' m0 : MeasurableSpace ő©}
    {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} [IsZeroOrMarkovKernel őļ] (h_indep : ‚ąÄ i, Indep (m i) m' őļ őľ)
    (h_le : ‚ąÄ i, m i ‚Č§ m0) (h_le' : m' ‚Č§ m0) (hm : Directed (¬∑ ‚Č§ ¬∑) m) :
    Indep (‚®Ü i, m i) m' őļ őľ := by
  let p : őĻ ‚Üí Set (Set ő©) := fun n => { t | MeasurableSet[m n] t }
  have hp : ‚ąÄ n, IsPiSystem (p n) := fun n => @isPiSystem_measurableSet ő© (m n)
  have h_gen_n : ‚ąÄ n, m n = generateFrom (p n) := fun n =>
    (@generateFrom_measurableSet ő© (m n)).symm
  have hp_supr_pi : IsPiSystem (‚čÉ n, p n) := isPiSystem_iUnion_of_directed_le p hp hm
  let p' := { t : Set ő© | MeasurableSet[m'] t }
  have hp'_pi : IsPiSystem p' := @isPiSystem_measurableSet ő© m'
  have h_gen' : m' = generateFrom p' := (@generateFrom_measurableSet ő© m').symm
  -- the ŌÄ-systems defined are independent
  have h_pi_system_indep : IndepSets (‚čÉ n, p n) p' őļ őľ := by
    refine IndepSets.iUnion ?_
    conv at h_indep =>
      intro i
      rw [h_gen_n i, h_gen']
    exact fun n => (h_indep n).indepSets
  -- now go from ŌÄ-systems to ŌÉ-algebras
  refine IndepSets.indep (iSup_le h_le) h_le' hp_supr_pi hp'_pi ?_ h_gen' h_pi_system_indep
  exact (generateFrom_iUnion_measurableSet _).symm

theorem iIndepSet.indep_generateFrom_lt [Preorder őĻ] {s : őĻ ‚Üí Set ő©}
    (hsm : ‚ąÄ n, MeasurableSet (s n)) (hs : iIndepSet s őļ őľ) (i : őĻ) :
    Indep (generateFrom {s i}) (generateFrom { t | ‚ąÉ j < i, s j = t }) őļ őľ := by
  convert iIndepSet.indep_generateFrom_of_disjoint hsm hs {i} { j | j < i }
    (Set.disjoint_singleton_left.mpr (lt_irrefl _)) using 1
  simp only [Set.mem_singleton_iff, exists_eq_left, Set.setOf_eq_eq_singleton']

theorem iIndepSet.indep_generateFrom_le [Preorder őĻ] {s : őĻ ‚Üí Set ő©}
    (hsm : ‚ąÄ n, MeasurableSet (s n)) (hs : iIndepSet s őļ őľ) (i : őĻ) {k : őĻ} (hk : i < k) :
    Indep (generateFrom {s k}) (generateFrom { t | ‚ąÉ j ‚Č§ i, s j = t }) őļ őľ := by
  convert iIndepSet.indep_generateFrom_of_disjoint hsm hs {k} { j | j ‚Č§ i }
      (Set.disjoint_singleton_left.mpr hk.not_ge) using 1
  simp only [Set.mem_singleton_iff, exists_eq_left, Set.setOf_eq_eq_singleton']

theorem iIndepSet.indep_generateFrom_le_nat {s : ‚Ąē ‚Üí Set ő©}
    (hsm : ‚ąÄ n, MeasurableSet (s n)) (hs : iIndepSet s őļ őľ) (n : ‚Ąē) :
    Indep (generateFrom {s (n + 1)}) (generateFrom { t | ‚ąÉ k ‚Č§ n, s k = t }) őļ őľ :=
  iIndepSet.indep_generateFrom_le hsm hs _ n.lt_succ_self

theorem indep_iSup_of_monotone [SemilatticeSup őĻ] {ő©} {m : őĻ ‚Üí MeasurableSpace ő©}
    {m' m0 : MeasurableSpace ő©} {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} [IsZeroOrMarkovKernel őļ]
    (h_indep : ‚ąÄ i, Indep (m i) m' őļ őľ) (h_le : ‚ąÄ i, m i ‚Č§ m0) (h_le' : m' ‚Č§ m0)
    (hm : Monotone m) :
    Indep (‚®Ü i, m i) m' őļ őľ :=
  indep_iSup_of_directed_le h_indep h_le h_le' (Monotone.directed_le hm)

theorem indep_iSup_of_antitone [SemilatticeInf őĻ] {ő©} {m : őĻ ‚Üí MeasurableSpace ő©}
    {m' m0 : MeasurableSpace ő©} {őļ : Kernel őĪ ő©} {őľ : Measure őĪ} [IsZeroOrMarkovKernel őļ]
    (h_indep : ‚ąÄ i, Indep (m i) m' őļ őľ) (h_le : ‚ąÄ i, m i ‚Č§ m0) (h_le' : m' ‚Č§ m0)
    (hm : Antitone m) :
    Indep (‚®Ü i, m i) m' őļ őľ :=
  indep_iSup_of_directed_le h_indep h_le h_le' hm.directed_le

theorem iIndepSets.piiUnionInter_of_notMem {ŌÄ : őĻ ‚Üí Set (Set ő©)} {a : őĻ} {S : Finset őĻ}
    (hp_ind : iIndepSets ŌÄ őļ őľ) (haS : a ‚ąČ S) :
    IndepSets (piiUnionInter ŌÄ S) (ŌÄ a) őļ őľ := by
  rintro t1 t2 ‚ü®s, hs_mem, ft1, hft1_mem, ht1_eq‚ü© ht2_mem_pia
  rw [Finset.coe_subset] at hs_mem
  classical
  let f := fun n => ite (n = a) t2 (ite (n ‚ąą s) (ft1 n) Set.univ)
  have h_f_mem : ‚ąÄ n ‚ąą insert a s, f n ‚ąą ŌÄ n := by
    intro n hn_mem_insert
    dsimp only [f]
    rcases Finset.mem_insert.mp hn_mem_insert with hn_mem | hn_mem
    ¬∑ simp [hn_mem, ht2_mem_pia]
    ¬∑ grind
  have h_f_mem_pi : ‚ąÄ n ‚ąą s, f n ‚ąą ŌÄ n := fun x hxS => h_f_mem x (by simp [hxS])
  have h_t1 : t1 = ‚čā n ‚ąą s, f n := by
    suffices h_forall : ‚ąÄ n ‚ąą s, f n = ft1 n by grind
    intro n hnS
    have hn_ne_a : n ‚Č† a := by rintro rfl; exact haS (hs_mem hnS)
    simp_rw [f, if_pos hnS, if_neg hn_ne_a]
  have h_őľ_t1 : ‚ąÄŠĶź a' ‚ąāőľ, őļ a' t1 = ‚ąŹ n ‚ąą s, őļ a' (f n) := by
    filter_upwards [hp_ind s h_f_mem_pi] with a' ha'
    rw [h_t1, ‚Üź ha']
  have h_t2 : t2 = f a := by simp [f]
  have h_őľ_inter : ‚ąÄŠĶź a' ‚ąāőľ, őļ a' (t1 ‚ą© t2) = ‚ąŹ n ‚ąą insert a s, őļ a' (f n) := by
    have h_t1_inter_t2 : t1 ‚ą© t2 = ‚čā n ‚ąą insert a s, f n := by
      rw [h_t1, h_t2, Finset.set_biInter_insert, Set.inter_comm]
    filter_upwards [hp_ind (insert a s) h_f_mem] with a' ha'
    rw [h_t1_inter_t2, ‚Üź ha']
  have has : a ‚ąČ s := fun has_mem => haS (hs_mem has_mem)
  filter_upwards [h_őľ_t1, h_őľ_inter] with a' ha1 ha2
  rw [ha2, Finset.prod_insert has, h_t2, mul_comm, ha1]

theorem iIndepSets.iIndep (m : őĻ ‚Üí MeasurableSpace ő©)
    (h_le : ‚ąÄ i, m i ‚Č§ _mő©) (ŌÄ : őĻ ‚Üí Set (Set ő©)) (h_pi : ‚ąÄ n, IsPiSystem (ŌÄ n))
    (h_generate : ‚ąÄ i, m i = generateFrom (ŌÄ i)) (h_ind : iIndepSets ŌÄ őļ őľ) :
    iIndep m őļ őľ := by
  classical
  rcases eq_or_ne őľ 0 with rfl | hőľ
  ¬∑ simp
  obtain ‚ü®ő∑, ő∑_eq, hő∑‚ü© : ‚ąÉ (ő∑ : Kernel őĪ ő©), őļ =ŠĶź[őľ] ő∑ ‚ąß IsMarkovKernel ő∑ :=
    exists_ae_eq_isMarkovKernel h_ind.ae_isProbabilityMeasure hőľ
  apply iIndep.congr (Filter.EventuallyEq.symm ő∑_eq)
  intro s f
  refine Finset.induction ?_ ?_ s
  ¬∑ simp
  ¬∑ intro a S ha_notin_S h_rec hf_m
    have hf_m_S : ‚ąÄ x ‚ąą S, MeasurableSet[m x] (f x) := fun x hx => hf_m x (by simp [hx])
    let p := piiUnionInter ŌÄ S
    set m_p := generateFrom p with hS_eq_generate
    have h_indep : Indep m_p (m a) ő∑ őľ := by
      have hp : IsPiSystem p := isPiSystem_piiUnionInter ŌÄ h_pi S
      have h_le' : ‚ąÄ i, generateFrom (ŌÄ i) ‚Č§ _mő© := fun i ‚Ü¶ (h_generate i).symm.trans_le (h_le i)
      have hm_p : m_p ‚Č§ _mő© := generateFrom_piiUnionInter_le ŌÄ h_le' S
      exact IndepSets.indep hm_p (h_le a) hp (h_pi a) hS_eq_generate (h_generate a)
        (iIndepSets.piiUnionInter_of_notMem (h_ind.congr ő∑_eq) ha_notin_S)
    have h := h_indep.symm (f a) (‚čā n ‚ąą S, f n) (hf_m a (Finset.mem_insert_self a S)) ?_
    ¬∑ filter_upwards [h_rec hf_m_S, h] with a' ha' h'
      rwa [Finset.set_biInter_insert, Finset.prod_insert ha_notin_S, ‚Üź ha']
    ¬∑ have h_le_p : ‚ąÄ i ‚ąą S, m i ‚Č§ m_p := by
        intro n hn
        rw [hS_eq_generate, h_generate n]
        exact le_generateFrom_piiUnionInter (S : Set őĻ) hn
      have h_S_f : ‚ąÄ i ‚ąą S, MeasurableSet[m_p] (f i) :=
        fun i hi ‚Ü¶ (h_le_p i hi) (f i) (hf_m_S i hi)
      exact S.measurableSet_biInter h_S_f

theorem iIndepSet_iff_iIndepSets_singleton {_mő© : MeasurableSpace ő©} {őļ : Kernel őĪ ő©}
    {őľ : Measure őĪ} {f : őĻ ‚Üí Set ő©} (hf : ‚ąÄ i, MeasurableSet (f i)) :
    iIndepSet f őļ őľ ‚ÜĒ iIndepSets (fun i ‚Ü¶ {f i}) őļ őľ :=
  ‚ü®iIndep.iIndepSets fun _ ‚Ü¶ rfl,
    iIndepSets.iIndep _ (fun i ‚Ü¶ generateFrom_le <| by rintro t (rfl : t = _); exact hf _) _

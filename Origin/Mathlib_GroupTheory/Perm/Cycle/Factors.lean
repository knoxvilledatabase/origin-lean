    آ· rw [union_sdiff_distrib, sdiff_singleton_eq_erase, erase_eq_of_notMem, mul_assoc,
        Disjoint.cycleFactorsFinset_mul_eq_union, hد„ hf]
      آ· rw [mem_cycleFactorsFinset_iff] at hf

def adF : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => ad (F i) ^ (-CM i j).toNat <| тБЕF i, F jтБЖ

def toSet [DecidableEq B] : Set (FreeLieAlgebra R (Generators B)) :=
  (Set.range <| HH R) тИк (Set.range <| EF R) тИк (Set.range <| HE R CM) тИк (Set.range <| HF R CM) тИк
    (Set.range <| adE R CM) тИк
    (Set.range <| adF R CM)

def toIdeal [DecidableEq B] : LieIdeal R (FreeLieAlgebra R (Generators B)) :=
  LieSubmodule.lieSpan R _ <| toSet R CM

end Relations


variable (R : Type u) {B : Type v} [CommRing R]

variable (A : Matrix B B тДд)

namespace CartanMatrix

variable (B)

inductive Generators
  | H : B тЖТ Generators
  | E : B тЖТ Generators
  | F : B тЖТ Generators

instance [Inhabited B] : Inhabited (Generators B) :=
  тЯиGenerators.H defaultтЯй

variable {B}

namespace Relations

open Function

local notation "H" => FreeLieAlgebra.of R тИШ Generators.H

local notation "E" => FreeLieAlgebra.of R тИШ Generators.E

local notation "F" => FreeLieAlgebra.of R тИШ Generators.F

local notation "ad" => LieAlgebra.ad R (FreeLieAlgebra R (Generators B))

def HH : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => тБЕH i, H jтБЖ

def EF [DecidableEq B] : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => if i = j then тБЕE i, F iтБЖ - H i else тБЕE i, F jтБЖ

def HE : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => тБЕH i, E jтБЖ - A i j тАв E j

def HF : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => тБЕH i, F jтБЖ + A i j тАв F j

def adE : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => ad (E i) ^ (-A i j).toNat <| тБЕE i, E jтБЖ

def adF : B ├Ч B тЖТ FreeLieAlgebra R (Generators B) :=
  uncurry fun i j => ad (F i) ^ (-A i j).toNat <| тБЕF i, F jтБЖ

private theorem adE_of_eq_eq_zero (i : B) (h : A i i = 2) : adE R A тЯиi, iтЯй = 0 := by
  have h' : (-2 : тДд).toNat = 0 := rfl
  simp [adE, h, h']

private theorem adF_of_eq_eq_zero (i : B) (h : A i i = 2) : adF R A тЯиi, iтЯй = 0 := by
  have h' : (-2 : тДд).toNat = 0 := rfl
  simp [adF, h, h']

def toSet [DecidableEq B] : Set (FreeLieAlgebra R (Generators B)) :=
  (Set.range <| HH R) тИк (Set.range <| EF R) тИк (Set.range <| HE R A) тИк (Set.range <| HF R A) тИк
      (Set.range <| adE R A) тИк
    (Set.range <| adF R A)

def toIdeal [DecidableEq B] : LieIdeal R (FreeLieAlgebra R (Generators B)) :=
  LieSubmodule.lieSpan R _ <| toSet R A

end Relations

end CartanMatrix

variable [DecidableEq B]

def Matrix.ToLieAlgebra :=
  FreeLieAlgebra R _ тз╕ CartanMatrix.Relations.toIdeal R A

instance Matrix.ToLieAlgebra.instLieRing : LieRing (Matrix.ToLieAlgebra R A) :=
  inferInstanceAs (LieRing (FreeLieAlgebra R _ тз╕ CartanMatrix.Relations.toIdeal R A))

instance Matrix.ToLieAlgebra.instInhabited : Inhabited (Matrix.ToLieAlgebra R A) :=
  inferInstanceAs (Inhabited (FreeLieAlgebra R _ тз╕ CartanMatrix.Relations.toIdeal R A))

instance Matrix.ToLieAlgebra.instLieAlgebra : LieAlgebra R (Matrix.ToLieAlgebra R A) :=
  inferInstanceAs (LieAlgebra R (FreeLieAlgebra R _ тз╕ CartanMatrix.Relations.toIdeal R A))


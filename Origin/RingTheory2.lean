universe u
variable {α β : Type u}

-- ============================================================================
-- 1. IDEALS
-- ============================================================================

/-- An ideal of a ring: closed under addition and absorption. -/
structure RingIdeal (α : Type u) [Mul α] [Add α] where
  mem : α → Prop
  add_closed : ∀ a b, mem a → mem b → mem (a + b)
  mul_absorb : ∀ r a, mem a → mem (r * a)

/-- Ideal membership on Option: none is not in any ideal. -/
def idealMem [Mul α] [Add α] (I : RingIdeal α) : Option α → Prop :=
  liftPred I.mem

@[simp] theorem idealMem_none [Mul α] [Add α] (I : RingIdeal α) :
    idealMem I none = False := rfl

@[simp] theorem idealMem_some [Mul α] [Add α] (I : RingIdeal α) (a : α) :
    idealMem I (some a) = I.mem a := rfl

/-- A prime ideal: ab ∈ I implies a ∈ I or b ∈ I. -/
def isPrimeIdeal' [Mul α] [Add α] (I : RingIdeal α) : Prop :=
  ∀ a b, I.mem (a * b) → I.mem a ∨ I.mem b

/-- A maximal ideal: not contained in any proper larger ideal. -/
def isMaximal' [Mul α] [Add α] (I : RingIdeal α) : Prop :=
  ∀ J : RingIdeal α, (∀ a, I.mem a → J.mem a) → (∃ a, J.mem a ∧ ¬I.mem a) →
    ∀ b, J.mem b

/-- The radical of an ideal: √I = {a | aⁿ ∈ I for some n}. -/
def radicalIdeal [Mul α] [Add α] (I : RingIdeal α)
    (powF : α → Nat → α) : α → Prop :=
  fun a => ∃ n, I.mem (powF a n)

/-- The Jacobson radical: intersection of all maximal ideals. -/
def jacobsonRadical [Mul α] [Add α] (isMax : RingIdeal α → Prop)
    (allIdeals : RingIdeal α → Prop) : α → Prop :=
  fun a => ∀ I, allIdeals I → isMax I → I.mem a

/-- Nakayama's lemma (abstract): M = IM implies M = 0 for f.g. modules. -/
def nakayama (isFinGen : Prop) (mEqualsIM : Prop) (mIsZero : Prop) : Prop :=
  isFinGen → mEqualsIM → mIsZero

-- ============================================================================
-- 2. LOCALIZATION
-- ============================================================================

/-- A multiplicative subset. -/
structure MulSubset (α : Type u) [Mul α] where
  mem : α → Prop
  mul_closed : ∀ a b, mem a → mem b → mem (a * b)

/-- Localization universal property: lifts through Option.map. -/
theorem localize_universal (loc f g : α → α) (v : Option α)
    (h : ∀ a, f a = g (loc a)) :
    Option.map f v = Option.map g (Option.map loc v) := by
  cases v <;> simp [h]

-- ============================================================================
-- 3. NOETHERIAN AND ARTINIAN
-- ============================================================================

/-- Noetherian: ascending chain condition on ideals. -/
def isNoetherian' [Mul α] [Add α] : Prop :=
  ∀ chain : Nat → RingIdeal α,
    (∀ n, ∀ a, (chain n).mem a → (chain (n + 1)).mem a) →
    ∃ N, ∀ n, N ≤ n → ∀ a, (chain n).mem a ↔ (chain N).mem a

/-- Artinian: descending chain condition on ideals. -/
def isArtinian' [Mul α] [Add α] : Prop :=
  ∀ chain : Nat → RingIdeal α,
    (∀ n, ∀ a, (chain (n + 1)).mem a → (chain n).mem a) →
    ∃ N, ∀ n, N ≤ n → ∀ a, (chain n).mem a ↔ (chain N).mem a

/-- Hilbert basis theorem (abstract): R Noetherian ⟹ R[x] Noetherian. -/
def hilbertBasis (rNoeth polyNoeth : Prop) : Prop :=
  rNoeth → polyNoeth

-- ============================================================================
-- 4. DEDEKIND DOMAINS AND PID
-- ============================================================================

/-- Dedekind domain: Noetherian + every nonzero prime is maximal. -/
def isDedekind' [Mul α] [Add α] : Prop :=
  isNoetherian' (α := α) ∧ ∀ I : RingIdeal α, isPrimeIdeal' I → isMaximal' I

/-- Principal ideal domain: every ideal is generated by one element. -/
def isPID' [Mul α] [Add α] : Prop :=
  ∀ I : RingIdeal α, ∃ g, ∀ a, I.mem a → ∃ r, r * g = a

/-- UFD: unique factorization into irreducibles. -/
def isUFD (factorF : α → List α) (isIrred : α → Prop)
    (_assocF : α → α → Prop) : Prop :=
  (∀ a, ∀ p ∈ factorF a, isIrred p) ∧
  (∀ a f₁ f₂, factorF a = f₁ → factorF a = f₂ → f₁.length = f₂.length)

-- ============================================================================
-- 5. POLYNOMIALS
-- ============================================================================

/-- Polynomial evaluation is a ring homomorphism. -/
def polyEval [Mul α] [Add α] (evalF : (Nat → α) → α → α) (coeffs : Nat → α)
    (x : α) : Option α :=
  some (evalF coeffs x)

/-- Irreducible polynomial: cannot be factored nontrivially. -/
def isIrredPoly (isUnit : α → Prop) (factorF : α → α × α) : α → Prop :=
  fun p => ∀ a b, factorF p = (a, b) → isUnit a ∨ isUnit b

-- ============================================================================
-- 6. GRADED RINGS
-- ============================================================================

/-- Grade of an element lifts to Option. -/
def gradeOf (gradeF : α → Nat) : Option α → Option Nat :=
  Option.map gradeF

@[simp] theorem gradeOf_none (gradeF : α → Nat) :
    gradeOf gradeF (none : Option α) = none := rfl

@[simp] theorem gradeOf_some (gradeF : α → Nat) (a : α) :
    gradeOf gradeF (some a) = some (gradeF a) := rfl

/-- Grades add under multiplication: grade(a·b) = grade(a) + grade(b). -/
theorem graded_mul [Mul α] (gradeF : α → Nat)
    (h : ∀ a b, gradeF (a * b) = gradeF a + gradeF b) (a b : α) :
    gradeOf gradeF (some a * some b) = some (gradeF a + gradeF b) := by
  simp [gradeOf, h]

-- ============================================================================
-- 7. TENSOR PRODUCT AND BASE CHANGE
-- ============================================================================

/-- Base change: apply a ring map to the first component. -/
def baseChange (f : α → α) : Option (α × β) → Option (α × β) :=
  Option.map (fun p => (f p.1, p.2))

theorem baseChange_none (f : α → α) :
    baseChange f (none : Option (α × β)) = none := rfl

theorem baseChange_some (f : α → α) (a : α) (b : β) :
    baseChange f (some (a, b)) = some (f a, b) := rfl

/-- Base change roundtrip: extend then restrict recovers the original. -/
theorem restrict_extend (f g : α → α) (v : Option (α × β))
    (h : ∀ a, g (f a) = a) : baseChange g (baseChange f v) = v := by
  cases v with
  | none => rfl
  | some p => simp [baseChange, h]

-- ============================================================================
-- 8. FLAT MODULES
-- ============================================================================

/-- A module is flat: tensoring preserves injectivity. -/
def isFlat' (tensorF : α → α → α) : Prop :=
  ∀ f : α → α, (∀ a b, f a = f b → a = b) →
    ∀ a b, tensorF (f a) b = tensorF (f b) b → f a = f b

-- ============================================================================
-- 9. INTEGRAL CLOSURE AND KRULL DIMENSION
-- ============================================================================

/-- An element is integral over a subring: root of a monic polynomial. -/
def isIntegralOver (monicRootF : α → Prop) : α → Prop := monicRootF

/-- The integral closure: all elements integral over R. -/
def integralClosure (isIntegral : α → Prop) : α → Prop := isIntegral

/-- Krull dimension: supremum of lengths of chains of prime ideals. -/
def krullDimension (maxChainLength : Nat) : Nat := maxChainLength

-- ============================================================================
-- 10. COMPLETION AND POWER SERIES
-- ============================================================================

/-- Completion of a ring at an ideal (abstract). -/
def completion (completeF : α → α) : α → α := completeF

/-- Formal power series: functions Nat → R. -/
def PowerSeries := Nat → α

-- ============================================================================
-- 11. CHINESE REMAINDER THEOREM
-- ============================================================================

/-- CRT: simultaneous quotient maps lift through Option. -/
theorem chinese_remainder (q₁ q₂ : α → α) (v : Option α) :
    Option.map (fun a => (q₁ a, q₂ a)) v =
    liftBin₂ Prod.mk (Option.map q₁ v) (Option.map q₂ v) := by
  cases v <;> simp

-- ============================================================================
-- 12. VALUATIONS
-- ============================================================================

/-- A valuation: multiplicative function to an ordered group. -/
def IsValuation [Mul α] [Add α] (v : α → β) (mulB : β → β → β)
    (leB : β → β → Prop) (maxB : β → β → β) : Prop :=
  (∀ a b, v (a * b) = mulB (v a) (v b)) ∧
  (∀ a b, leB (v (a + b)) (maxB (v a) (v b)))


/-!
## ╬╕ as a ring homomorphism
Let `ЁЭФн` denote the ideal of `R` generated by the prime number `p`. In this section, we first
define the ring homomorphism `fontaineThetaModPPow : ЁЭХО RтЩн тЖТ+* R тз╕ ЁЭФн ^ (n + 1)`.
Then we show they are compatible with each other and lift to a
ring homomorphism `fontaineTheta : ЁЭХО RтЩн тЖТ+* R`.

To prove this, we define `fontaineThetaModPPow` as a composition of the following ring
homomorphisms.

`ЁЭХО RтЩн --ЁЭХО(Frob^-n)-> ЁЭХО RтЩн --ЁЭХО(coeff 0)-> ЁЭХО(R/ЁЭФн) --gh_n-> R/ЁЭФн^(n+1)`

Here, the ring map `gh_n` fits in the following diagram.

```
ЁЭХО(R)  --ghost_n->   R
|                   |
v                   v
ЁЭХО(R/ЁЭФн) --gh_n-> R/ЁЭФн^(n+1)
```
-/

theorem ker_map_le_ker_mk_comp_ghostComponent (n : тДХ) :
    RingHom.ker (WittVector.map (Ideal.Quotient.mk ЁЭФн)) тЙд
    RingHom.ker (((Ideal.Quotient.mk (ЁЭФн ^ (n + 1)))).comp
    (WittVector.ghostComponent (p := p) n)) := by
  intro x
  simp only [RingHom.mem_ker, map_eq_zero_iff, RingHom.comp_apply]
  intro h
  simp only [ghostComponent]
  apply_fun Ideal.quotEquivOfEq (Ideal.span_singleton_pow _ (n + 1))
  simp only [RingHom.coe_comp, Function.comp_apply, Pi.evalRingHom_apply, ghostMap_apply,
    quotEquivOfEq_mk, map_zero]
  simp only [eq_zero_iff_dvd] at h тКв
  exact pow_dvd_ghostComponent_of_dvd_coeff (fun _ _ тЖж h _)

def ghostComponentModPPow (n : тДХ) : ЁЭХО (R тз╕ ЁЭФн) тЖТ+* R тз╕ ЁЭФн ^ (n + 1) :=
  RingHom.liftOfSurjective (WittVector.map (Ideal.Quotient.mk ЁЭФн))
    (map_surjective _ Ideal.Quotient.mk_surjective) тЯи((Ideal.Quotient.mk (ЁЭФн ^ (n + 1)))).comp
      (WittVector.ghostComponent n), ker_map_le_ker_mk_comp_ghostComponent nтЯй

lemma rel_iff (x y : R) : I.ringCon x y ↔ x - y ∈ I := by
  rw [mem_iff]
  constructor
  · intro h; convert I.ringCon.sub h (I.ringCon.refl y); abel
  · intro h; convert I.ringCon.add h (I.ringCon.refl y) <;> abel


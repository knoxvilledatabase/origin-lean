  { Filter.monoid, Filter.instInvolutiveInv, Filter.instDiv, Filter.instZPow (╬▒ := ╬▒) with
    mul_inv_rev := fun _ _ => map_mapРѓѓ_antidistrib mul_inv_rev
    inv_eq_of_mul := fun s t h => by
      obtain РЪеa, b, rfl, rfl, habРЪЕ := Filter.mul_eq_one_iff.1 h
      rw [inv_pure, inv_eq_of_mul_eq_one_right hab]
    div_eq_mul_inv := fun _ _ => map_mapРѓѓ_distrib_right div_eq_mul_inv }

@[to_additive]
theorem isUnit_iff : IsUnit f Рєћ РѕЃ a, f = pure a РѕД IsUnit a := by
  constructor
  ┬и rintro РЪеu, rflРЪЕ
    obtain РЪеa, b, ha, hb, hРЪЕ := Filter.mul_eq_one_iff.1 u.mul_inv
    refine РЪеa, ha, РЪеa, b, h, pure_injective ?_РЪЕ, rflРЪЕ
    rw [Рєљ pure_mul_pure, Рєљ ha, Рєљ hb]
    exact u.inv_mul
  ┬и rintro РЪеa, rfl, haРЪЕ
    exact ha.filter


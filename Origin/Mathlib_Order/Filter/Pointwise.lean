@[to_additive "An additive action of an additive monoid `╬▒` on a type `╬▓` gives an additive action
 of `Filter ╬▒` on `Filter ╬▓`"]
protected def mulAction [Monoid ╬▒] [MulAction ╬▒ ╬▓] : MulAction (Filter ╬▒) (Filter ╬▓) where
  one_smul f := mapРѓѓ_pure_left.trans <| by simp_rw [one_smul, map_id']
  mul_smul _ _ _ := mapРѓѓ_assoc mul_smul

@[to_additive "An additive action of an additive monoid on a type `╬▓` gives an additive action on
 `Filter ╬▓`."]
protected def mulActionFilter [Monoid ╬▒] [MulAction ╬▒ ╬▓] : MulAction ╬▒ (Filter ╬▓) where
  mul_smul a b f := by simp only [Рєљ Filter.map_smul, map_map, Function.comp_def, Рєљ mul_smul]
  one_smul f := by simp only [Рєљ Filter.map_smul, one_smul, map_id']

scoped[Pointwise] attribute [instance] Filter.mulAction Filter.addAction Filter.mulActionFilter

  Filter.addActionFilter

protected def distribMulActionFilter [Monoid ╬▒] [AddMonoid ╬▓] [DistribMulAction ╬▒ ╬▓] :
    DistribMulAction ╬▒ (Filter ╬▓) where
  smul_add _ _ _ := map_mapРѓѓ_distrib <| smul_add _

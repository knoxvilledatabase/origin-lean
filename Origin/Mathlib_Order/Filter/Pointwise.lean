protected theorem mul_eq_one_iff : f * g = 1 Рєћ РѕЃ a b, f = pure a РѕД g = pure b РѕД a * b = 1 := by
  refine РЪеfun hfg => ?_, ?_РЪЕ
  ┬и obtain РЪеtРѓЂ, hРѓЂ, tРѓѓ, hРѓѓ, hРЪЕ : (1 : Set ╬▒) Рѕѕ f * g := hfg.symm РќИ one_mem_one
    have hfg : (f * g).NeBot := hfg.symm.subst one_neBot
    rw [(hfg.nonempty_of_mem <| mul_mem_mul hРѓЂ hРѓѓ).subset_one_iff, Set.mul_eq_one_iff] at h
    obtain РЪеa, b, rfl, rfl, hРЪЕ := h
    refine РЪеa, b, ?_, ?_, hРЪЕ
    ┬и rwa [Рєљ hfg.of_mul_left.le_pure_iff, le_pure_iff]
    ┬и rwa [Рєљ hfg.of_mul_right.le_pure_iff, le_pure_iff]
  ┬и rintro РЪеa, b, rfl, rfl, hРЪЕ
    rw [pure_mul_pure, h, pure_one]


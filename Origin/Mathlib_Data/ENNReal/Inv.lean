      using le_iSup_of_le (f := fun i => тКд * f i) i (top_mul hi).ge
  ┬╖ exact (mulLeftOrderIso _ <| isUnit_iff.2 тЯиhaтВА, haтЯй).map_iSup _

lemma iSup_mul (f : ╬╣ тЖТ тДЭтЙе0тИЮ) (a : тДЭтЙе0тИЮ) : (тиЖ i, f i) * a = тиЖ i, f i * a := by
  simp [mul_comm, mul_iSup]

lemma mul_sSup {a : тДЭтЙе0тИЮ} : a * sSup s = тиЖ b тИИ s, a * b := by
  simp only [sSup_eq_iSup, mul_iSup]

lemma sSup_mul {a : тДЭтЙе0тИЮ} : sSup s * a = тиЖ b тИИ s, b * a := by
  simp only [sSup_eq_iSup, iSup_mul]

lemma iSup_div (f : ╬╣ тЖТ тДЭтЙе0тИЮ) (a : тДЭтЙе0тИЮ) : iSup f / a = тиЖ i, f i / a := iSup_mul ..

lemma sSup_div (s : Set тДЭтЙе0тИЮ) (a : тДЭтЙе0тИЮ) : sSup s / a = тиЖ b тИИ s, b / a := sSup_mul ..

lemma mul_iInf' (hinfty : a = тИЮ тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) (hтВА : a = 0 тЖТ Nonempty ╬╣) :
    a * тиЕ i, f i = тиЕ i, a * f i := by
  obtain rfl | haтВА := eq_or_ne a 0
  ┬╖ simp [hтВА rfl]
  obtain rfl | ha := eq_or_ne a тИЮ
  ┬╖ obtain тЯиi, hiтЯй | hf := em (тИГ i, f i = 0)
    ┬╖ rw [(iInf_eq_bot _).2, (iInf_eq_bot _).2, bot_eq_zero, mul_zero] <;>
        exact fun _ _ тЖж тЯиi, by simpa [hi]тЯй
    ┬╖ rw [top_mul (mt (hinfty rfl) hf), eq_comm, iInf_eq_top]
      exact fun i тЖж top_mul fun hi тЖж hf тЯиi, hiтЯй
  ┬╖ exact (mulLeftOrderIso _ <| isUnit_iff.2 тЯиhaтВА, haтЯй).map_iInf _

lemma iInf_mul' (hinfty : a = тИЮ тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) (hтВА : a = 0 тЖТ Nonempty ╬╣) :
    (тиЕ i, f i) * a = тиЕ i, f i * a := by simpa only [mul_comm a] using mul_iInf' hinfty hтВА

lemma mul_iInf [Nonempty ╬╣] (hinfty : a = тИЮ тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) :
    a * тиЕ i, f i = тиЕ i, a * f i := mul_iInf' hinfty fun _ тЖж тА╣Nonempty ╬╣тА║

lemma iInf_mul [Nonempty ╬╣] (hinfty : a = тИЮ тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) :
    (тиЕ i, f i) * a = тиЕ i, f i * a := iInf_mul' hinfty fun _ тЖж тА╣Nonempty ╬╣тА║

lemma iInf_div' (hinfty : a = 0 тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) (hтВА : a = тИЮ тЖТ Nonempty ╬╣) :
    (тиЕ i, f i) / a = тиЕ i, f i / a := iInf_mul' (by simpa) (by simpa)

lemma iInf_div [Nonempty ╬╣] (hinfty : a = 0 тЖТ тиЕ i, f i = 0 тЖТ тИГ i, f i = 0) :
    (тиЕ i, f i) / a = тиЕ i, f i / a := iInf_div' hinfty fun _ тЖж тА╣Nonempty ╬╣тА║

lemma inv_iInf (f : ╬╣ тЖТ тДЭтЙе0тИЮ) : (тиЕ i, f i)тБ╗┬╣ = тиЖ i, (f i)тБ╗┬╣ := OrderIso.invENNReal.map_iInf _

lemma inv_iSup (f : ╬╣ тЖТ тДЭтЙе0тИЮ) : (тиЖ i, f i)тБ╗┬╣ = тиЕ i, (f i)тБ╗┬╣ := OrderIso.invENNReal.map_iSup _

lemma inv_sInf (s : Set тДЭтЙе0тИЮ) : (sInf s)тБ╗┬╣ = тиЖ a тИИ s, aтБ╗┬╣ := by simp [sInf_eq_iInf, inv_iInf]

lemma inv_sSup (s : Set тДЭтЙе0тИЮ) : (sSup s)тБ╗┬╣ = тиЕ a тИИ s, aтБ╗┬╣ := by simp [sSup_eq_iSup, inv_iSup]

lemma le_iInf_mul {╬╣ : Type*} (u v : ╬╣ тЖТ тДЭтЙе0тИЮ) :
    (тиЕ i, u i) * тиЕ i, v i тЙд тиЕ i, u i * v i :=
  le_iInf fun i тЖж mul_le_mul' (iInf_le u i) (iInf_le v i)

lemma iSup_mul_le {╬╣ : Type*} {u v : ╬╣ тЖТ тДЭтЙе0тИЮ} :
    тиЖ i, u i * v i тЙд (тиЖ i, u i) * тиЖ i, v i :=
  iSup_le fun i тЖж mul_le_mul' (le_iSup u i) (le_iSup v i)

lemma le_iInf_mul_iInf {g : ╬║ тЖТ тДЭтЙе0тИЮ} (hf : тИГ i, f i тЙа тИЮ) (hg : тИГ j, g j тЙа тИЮ)
    (ha : тИА i j, a тЙд f i * g j) : a тЙд (тиЕ i, f i) * тиЕ j, g j := by
  rw [тЖР iInf_ne_top_subtype]
  have := nonempty_subtype.2 hf
  have := hg.nonempty
  replace hg : тиЕ j, g j тЙа тИЮ := by simpa using hg
  rw [iInf_mul fun h тЖж (hg h).elim, le_iInf_iff]
  rintro тЯиi, hiтЯй
  simpa [mul_iInf fun h тЖж (hi h).elim] using ha i

lemma smul_iSup {R} [SMul R тДЭтЙе0тИЮ] [IsScalarTower R тДЭтЙе0тИЮ тДЭтЙе0тИЮ] (f : ╬╣ тЖТ тДЭтЙе0тИЮ) (c : R) :
    c тАв тиЖ i, f i = тиЖ i, c тАв f i := by
  simp only [тЖР smul_one_mul c (f _), тЖР smul_one_mul c (iSup _), ENNReal.mul_iSup]

lemma smul_sSup {R} [SMul R тДЭтЙе0тИЮ] [IsScalarTower R тДЭтЙе0тИЮ тДЭтЙе0тИЮ] (s : Set тДЭтЙе0тИЮ) (c : R) :
    c тАв sSup s = тиЖ a тИИ s, c тАв a := by
  simp_rw [тЖР smul_one_mul c (sSup s), ENNReal.mul_sSup, smul_one_mul]

theorem ofReal_inv_of_pos {x : тДЭ} (hx : 0 < x) : ENNReal.ofReal xтБ╗┬╣ = (ENNReal.ofReal x)тБ╗┬╣ := by
  rw [ENNReal.ofReal, ENNReal.ofReal, тЖР @coe_inv (Real.toNNReal x) (by simp [hx]), coe_inj,
    тЖР Real.toNNReal_inv]

theorem ofReal_inv_le {x : тДЭ} : ENNReal.ofReal xтБ╗┬╣ тЙд (ENNReal.ofReal x)тБ╗┬╣ := by
  obtain hx | hx := lt_or_ge 0 x
  ┬╖ simp [ofReal_inv_of_pos hx]
  ┬╖ simp [ofReal_of_nonpos hx]

theorem ofReal_div_le {x y : тДЭ} (hy : 0 тЙд y) :
    ENNReal.ofReal (x / y) тЙд ENNReal.ofReal x / ENNReal.ofReal y := by
  simp_rw [div_eq_mul_inv, ofReal_mul' (inv_nonneg.2 hy)]
  gcongr
  exact ofReal_inv_le

theorem ofReal_div_of_pos {x y : тДЭ} (hy : 0 < y) :
    ENNReal.ofReal (x / y) = ENNReal.ofReal x / ENNReal.ofReal y := by
  rw [div_eq_mul_inv, div_eq_mul_inv, ofReal_mul' (inv_nonneg.2 hy.le), ofReal_inv_of_pos hy]

